{
  "name": "@modmux/cli",
  "version": "0.3.0",
  "license": "MIT",
  "exports": {
    ".": "./src/main.ts"
  },
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "imports": {
    "@modmux/gateway": "../gateway/src/mod.ts",
    "@modmux/providers": "../providers/src/mod.ts",
    "@cliffy/ansi": "jsr:@cliffy/ansi@1",
    "@cliffy/keypress": "jsr:@cliffy/keypress@1",
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@std/fmt": "jsr:@std/fmt@^1.0.9",
    "@std/path": "jsr:@std/path@^1.1.4"
  },
  "tasks": {
    "install": "deno install --global --allow-all --config deno.json -n modmux --force src/main.ts",
    "dev": "deno run -A src/main.ts",
    "compile": "deno compile --allow-net --allow-env --allow-run --allow-read --allow-write --output ../../bin/modmux src/main.ts"
  }
}
