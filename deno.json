{
  "name": "@myty/coco",
  "version": "0.2.0",
  "exports": {
    ".": "./src/cli/main.ts"
  },
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "imports": {
    "@cliffy/ansi": "jsr:@cliffy/ansi@1",
    "@cliffy/keypress": "jsr:@cliffy/keypress@1",
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@std/fmt": "jsr:@std/fmt@^1.0.9",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/toml": "jsr:@std/toml@^1.0.11",
    "@std/yaml": "jsr:@std/yaml@^1.0.12"
  },
  "tasks": {
    "dev": "deno run -A src/cli/main.ts",
    "test": "deno test --allow-all",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "check": "deno check src/**/*.ts tests/**/*.ts",
    "quality": "deno lint && deno fmt --check && deno check && deno test --allow-all",
    "sync-version": "deno run -A scripts/sync-version.ts",
    "compile": "deno compile --allow-net --allow-env --allow-run --allow-read --allow-write --output bin/coco src/cli/main.ts"
  }
}
